    "db:up": "docker compose up -d",
    "db:embedded": "node scripts/embedded-db.mjs",
    "launch": "node scripts/launch.mjs",
    "poll": "tsx scripts/poll.ts",
    "data:claim-all": "tsx scripts/claim-all-data.ts",
    "data:claim-legacy": "tsx scripts/claim-legacy-data.ts",
    "seed": "tsx prisma/seed.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.3",
    "@capacitor/cli": "^8.3.3",
    "@capacitor/core": "^8.3.3",
