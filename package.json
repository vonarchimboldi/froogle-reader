{
  "name": "froogle-reader",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "build:mobile": "node scripts/build-mobile.mjs",
    "start": "next start",
    "lint": "next lint",
    "cap:sync": "npm run build:mobile && npx cap sync android",
    "cap:open": "npx cap open android",
