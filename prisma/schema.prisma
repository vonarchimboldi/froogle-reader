generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceType {
  RSS
  AUTHOR_PAGE
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  writers      Writer[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Writer {
  id             String     @id @default(cuid())
  userId         String
  name           String
  publication    String?
  sourceUrl      String
  sourceType     SourceType
  selectorConfig Json?
  lastCheckedAt  DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  articles       Article[]

  @@unique([userId, sourceUrl])
  @@index([userId])
}

model Article {
  id           String   @id @default(cuid())
  writerId     String
  title        String
  url          String
  canonicalUrl String
  summary      String?
  publishedAt  DateTime?
  discoveredAt DateTime @default(now())
  isRead       Boolean  @default(false)
  isFavorite   Boolean  @default(false)
  isBookmarked Boolean  @default(false)
  rawData      Json?
  writer       Writer   @relation(fields: [writerId], references: [id], onDelete: Cascade)

  @@index([writerId])
  @@index([publishedAt])
  @@index([discoveredAt])
  @@unique([writerId, canonicalUrl])
}
