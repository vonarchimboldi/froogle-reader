DATABASE_URL="postgresql://postgres:postgres@localhost:5432/writer_reader?schema=public"

# Required for AI-assisted source lookup.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"

# Production backend URL used when building Android assets.
# Required for bundled Capacitor builds unless the API is hosted at the same origin.
# Example: NEXT_PUBLIC_API_BASE_URL="https://writer-reader.example.com"
NEXT_PUBLIC_API_BASE_URL=""

# Optional: restrict API CORS for hosted backends used by the Android WebView.
# For Capacitor Android, use API_ALLOWED_ORIGIN="capacitor://localhost".
API_ALLOWED_ORIGIN=""
